<UserControl x:Class="NormAdvisor.AutoCAD1.Views.MainPaletteControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:NormAdvisor.AutoCAD1.Views">

    <UserControl.Resources>
        <ResourceDictionary Source="Styles/NormStyles.xaml" />
    </UserControl.Resources>

    <Grid Background="{StaticResource BgDarkBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource BgMediumBrush}"
                Padding="12,8"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <TextBlock Text="NormAdvisor Pro"
                       Style="{StaticResource NormTitle}"
                       FontSize="15" />
        </Border>

        <TabControl Grid.Row="1"
                    Style="{StaticResource NormTabControl}"
                    SelectedIndex="{Binding SelectedTabIndex}">
            <TabItem Style="{StaticResource NormTabItem}" Header="Өрөө">
                <views:RoomListView DataContext="{Binding RoomList}" />
            </TabItem>

            <TabItem Style="{StaticResource NormTabItem}" Header="Төхөөрөмж">
                <views:DeviceCatalogView DataContext="{Binding DeviceCatalog}" />
            </TabItem>

            <TabItem Style="{StaticResource NormTabItem}" Header="Норм" IsEnabled="False">
                <Grid Background="{StaticResource BgDarkBrush}">
                    <TextBlock Text="Удахгүй нэмэгдэнэ..."
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="13" />
                </Grid>
            </TabItem>

            <TabItem Style="{StaticResource NormTabItem}" Header="Угсралтын бүдүүвч">
                <views:SchematicView DataContext="{Binding Schematic}" />
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
