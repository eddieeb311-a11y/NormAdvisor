<Window x:Class="NormSchematicStudio.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Norm Schematic Studio"
        Height="940"
        Width="1680"
        WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown"
        Loaded="MainWindow_Loaded"
        Background="#0B0F14"
        FontFamily="Segoe UI">
    <Window.Resources>
        <SolidColorBrush x:Key="ShellBg" Color="#0B0F14"/>
        <SolidColorBrush x:Key="TopBg" Color="#0F1520"/>
        <SolidColorBrush x:Key="PanelBg" Color="#141C28"/>
        <SolidColorBrush x:Key="PanelBorder" Color="#2B3646"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#E8EEF7"/>
        <SolidColorBrush x:Key="TextMuted" Color="#95A3B6"/>
        <SolidColorBrush x:Key="Accent" Color="#2EA8FF"/>

        <Style x:Key="ToolButton" TargetType="Button">
            <Setter Property="Foreground" Value="#E8EEF7"/>
            <Setter Property="Background" Value="#1D2734"/>
            <Setter Property="BorderBrush" Value="#334256"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#263447"/>
                                <Setter Property="BorderBrush" Value="#4A617D"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#192330"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource ToolButton}">
            <Setter Property="Background" Value="#1264A3"/>
            <Setter Property="BorderBrush" Value="#2EA8FF"/>
        </Style>

        <Style x:Key="FieldBox" TargetType="TextBox">
            <Setter Property="Foreground" Value="#E8EEF7"/>
            <Setter Property="Background" Value="#0F151E"/>
            <Setter Property="BorderBrush" Value="#324156"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="#D8E0EB"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="8,6"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1D2734"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#203247"/>
                    <Setter Property="Foreground" Value="#E8EEF7"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource ShellBg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource TopBg}" BorderBrush="#212B3A" BorderThickness="0,0,0,1" Padding="14,10">
            <DockPanel>
                <Border DockPanel.Dock="Left" Background="#121A26" BorderBrush="#2B3646" BorderThickness="1" CornerRadius="8" Padding="10,6" Margin="0,0,10,0">
                    <TextBlock Text="NORM SCHEMATIC STUDIO" Foreground="#B9D8F0" FontSize="13" FontWeight="Bold"/>
                </Border>

                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#121A26" BorderBrush="#2B3646" BorderThickness="1" CornerRadius="8" Padding="6" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="SelectToolButton" Content="Select" Style="{StaticResource ToolButton}" Width="82" Click="SelectTool_Click"/>
                            <Button x:Name="DeviceToolButton" Content="Device" Style="{StaticResource ToolButton}" Width="84" Click="AddDeviceTool_Click"/>
                            <Button x:Name="TextToolButton" Content="Text" Style="{StaticResource ToolButton}" Width="74" Click="AddTextTool_Click"/>
                            <Button x:Name="ConnectToolButton" Content="Connect" Style="{StaticResource ToolButton}" Width="88" Margin="0" Click="ConnectTool_Click"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#121A26" BorderBrush="#2B3646" BorderThickness="1" CornerRadius="8" Padding="8,6" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Floors" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox x:Name="FloorsBox" Width="58" Style="{StaticResource FieldBox}" Text="5" Margin="0,0,10,0"/>
                            <TextBlock Text="LAN/Floor" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox x:Name="LanBox" Width="58" Style="{StaticResource FieldBox}" Text="10"/>
                        </StackPanel>
                    </Border>

                    
                    <Border Background="#121A26" BorderBrush="#2B3646" BorderThickness="1" CornerRadius="8" Padding="8,6" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Orientation" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <ComboBox x:Name="OrientationBox" Width="110" SelectedIndex="0" SelectionChanged="OrientationBox_SelectionChanged" Margin="0,0,8,0">
                                <ComboBoxItem Content="Portrait"/>
                                <ComboBoxItem Content="Landscape"/>
                            </ComboBox>
                            <TextBlock Text="Pages" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox x:Name="PagesBox" Width="44" Style="{StaticResource FieldBox}" Text="1" Margin="0,0,8,0"/>
                            <Button Content="Apply Layout" Style="{StaticResource ToolButton}" Width="108" Margin="0" Click="ApplyLayout_Click"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#121A26" BorderBrush="#2B3646" BorderThickness="1" CornerRadius="8" Padding="6">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Generate" Style="{StaticResource PrimaryButton}" Width="96" Click="Generate_Click"/>
                            <Button Content="Validate" Style="{StaticResource ToolButton}" Width="92" Click="Validate_Click"/>
                            <Button Content="Undo" Style="{StaticResource ToolButton}" Width="72" Click="Undo_Click"/>
                            <Button Content="Redo" Style="{StaticResource ToolButton}" Width="72" Margin="0" Click="Redo_Click"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Border DockPanel.Dock="Right" Background="#121A26" BorderBrush="#2B3646" BorderThickness="1" CornerRadius="8" Padding="10,6">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Zoom" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Slider x:Name="ZoomSlider" Width="170" Minimum="0.25" Maximum="3" Value="1" ValueChanged="ZoomSlider_ValueChanged"/>
                        <TextBlock x:Name="ZoomText" Text="100%" Width="52" TextAlignment="Right" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" Margin="8,0,0,0" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="330"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource PanelBg}" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="10" Padding="8">
                <ScrollViewer x:Name="EditorScroll" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" PreviewMouseWheel="EditorScroll_PreviewMouseWheel" PreviewMouseDown="EditorScroll_PreviewMouseDown" PreviewMouseMove="EditorScroll_PreviewMouseMove" PreviewMouseUp="EditorScroll_PreviewMouseUp">
                    <Canvas x:Name="PreviewCanvas"
                            Width="2400"
                            Height="1800"
                            Background="#FFFFFF"
                            MouseLeftButtonDown="PreviewCanvas_MouseLeftButtonDown"
                            MouseLeftButtonUp="PreviewCanvas_MouseLeftButtonUp"
                            MouseMove="PreviewCanvas_MouseMove"
                            MouseDown="PreviewCanvas_MouseDown"
                            MouseUp="PreviewCanvas_MouseUp"/>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="1" Margin="10,0,0,0" Background="{StaticResource PanelBg}" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="10" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="124"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <TextBlock Text="Properties" Foreground="{StaticResource TextPrimary}" FontSize="15" FontWeight="Bold"/>
                        <TextBlock Text="  •  Tool: " Foreground="{StaticResource TextMuted}" Margin="10,0,0,0"/>
                        <TextBlock x:Name="ToolText" Text="Select" Foreground="{StaticResource Accent}" FontWeight="Bold"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="0,10,0,0">
                        <TextBlock Text="Selected Label" Foreground="{StaticResource TextMuted}"/>
                        <TextBox x:Name="SelectedLabelBox" Style="{StaticResource FieldBox}" TextChanged="SelectedLabelBox_TextChanged" Margin="0,4,0,0"/>
                        <TextBlock Text="Type" Foreground="{StaticResource TextMuted}" Margin="0,8,0,0"/>
                        <TextBlock x:Name="SelectedTypeText" Text="-" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold"/>
                    </StackPanel>

                    <TextBlock Grid.Row="3" Text="Rule Check" Foreground="{StaticResource TextPrimary}" FontSize="15" FontWeight="Bold"/>
                    <Border Grid.Row="4" BorderBrush="#2F3A4A" BorderThickness="1" CornerRadius="8" Background="#0F151E">
                        <ListBox x:Name="RuleList" Background="#0F151E" Foreground="#D5DEE9" BorderThickness="0"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="{StaticResource TopBg}" BorderBrush="#212B3A" BorderThickness="0,1,0,0" Padding="12,8">
            <TextBlock x:Name="StatusText" Text="Ready" Foreground="{StaticResource TextMuted}"/>
        </Border>
    </Grid>
</Window>



