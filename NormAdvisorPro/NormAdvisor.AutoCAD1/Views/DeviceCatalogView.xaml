<UserControl x:Class="NormAdvisor.AutoCAD1.Views.DeviceCatalogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <ResourceDictionary Source="Styles/NormStyles.xaml" />
    </UserControl.Resources>

    <Grid Margin="10" Background="{StaticResource BgDarkBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Категори гарчиг -->
        <TextBlock Grid.Row="0" Text="Категори" Style="{StaticResource NormLabel}" />

        <!-- Категори товчнууд (WrapPanel) -->
        <ItemsControl Grid.Row="1"
                      ItemsSource="{Binding Categories}"
                      Margin="0,0,0,10">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <RadioButton GroupName="Category"
                                 IsChecked="{Binding IsSelected, RelativeSource={RelativeSource Self}}"
                                 Checked="CategorySelected"
                                 Tag="{Binding}"
                                 Margin="0,0,6,6"
                                 Cursor="Hand">
                        <RadioButton.Template>
                            <ControlTemplate TargetType="RadioButton">
                                <Border x:Name="CardBorder"
                                        Style="{StaticResource CategoryCard}"
                                        MinWidth="70"
                                        MinHeight="55">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding Icon}"
                                                   FontSize="20"
                                                   HorizontalAlignment="Center" />
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="10"
                                                   HorizontalAlignment="Center"
                                                   TextWrapping="Wrap"
                                                   MaxWidth="65"
                                                   TextAlignment="Center"
                                                   Margin="0,2,0,0" />
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter TargetName="CardBorder" Property="BorderBrush" Value="{StaticResource AccentBlueBrush}" />
                                        <Setter TargetName="CardBorder" Property="Background" Value="{StaticResource BgSelectedBrush}" />
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="CardBorder" Property="Background" Value="{StaticResource BgHoverBrush}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </RadioButton.Template>
                    </RadioButton>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Төхөөрөмжийн жагсаалт -->
        <ListBox Grid.Row="2"
                 Style="{StaticResource NormListBox}"
                 ItemsSource="{Binding Devices}"
                 SelectedItem="{Binding SelectedDevice}"
                 ItemContainerStyle="{StaticResource NormListBoxItem}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Tag prefix -->
                        <Border Grid.Column="0"
                                Background="{StaticResource BgLightBrush}"
                                CornerRadius="3"
                                Padding="4,2"
                                Margin="0,0,8,0"
                                VerticalAlignment="Center">
                            <TextBlock Text="{Binding TagPrefix}"
                                       Foreground="{StaticResource AccentOrangeBrush}"
                                       FontSize="10"
                                       FontWeight="Bold" />
                        </Border>

                        <!-- Нэр -->
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Name}"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"
                                   FontSize="12" />

                        <!-- Байршуулах товч -->
                        <Button Grid.Column="2"
                                Style="{StaticResource NormSmallButton}"
                                Content="&#9654;"
                                Command="{Binding DataContext.PlaceDeviceCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                CommandParameter="{Binding}"
                                ToolTip="Байршуулах"
                                VerticalAlignment="Center" />
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Footer -->
        <Border Grid.Row="3"
                Background="{StaticResource BgLightBrush}"
                CornerRadius="0,0,4,4"
                Padding="10,6"
                Margin="0,4,0,0">
            <TextBlock Text="{Binding StatusText}"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="11" />
        </Border>
    </Grid>
</UserControl>
